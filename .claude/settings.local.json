{
  "permissions": {
    "allow": [
      "Bash(npm install:*)",
      "Read(//usr/local/bin/**)",
      "Bash(export PATH=\"$PATH:/opt/homebrew/bin:/usr/local/bin\")",
      "Bash(/opt/homebrew/bin/npm install:*)",
      "Read(//opt/homebrew/bin/**)",
      "Bash(/opt/homebrew/bin/node --version)",
      "Bash(PATH=\"/opt/homebrew/bin:$PATH\" npm install)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:3002/)"
    ]
  }
}
